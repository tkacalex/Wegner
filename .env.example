# =====================================================================
# Wegner Automobile – Umgebungsvariablen
# Diese Datei nach ".env.local" kopieren und Werte eintragen.
# .env.local NIEMALS committen (siehe .gitignore).
# In Vercel: Project Settings -> Environment Variables eintragen.
# =====================================================================

# --- Basis-URL der Seite ---------------------------------------------
# Lokal:        http://localhost:3000
# Vercel:       https://<projekt>.vercel.app
# Custom Domain: https://wegner-automobile.de  (sobald vorhanden)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- AutoScout24 -----------------------------------------------------
# Link zum Händlerprofil / zur Fahrzeugliste auf AutoScout24.
# TODO: echten AutoScout24-Link eintragen, sobald bekannt.
NEXT_PUBLIC_AUTOSCOUT24_URL="AUTO_SCOUT24_LINK_HIER_EINFUEGEN"

# --- Google Maps (optional) ------------------------------------------
# Embed-URL (iframe src) für die Standortkarte. Wird erst nach Klick
# des Nutzers geladen (Datenschutz). Leer lassen = Karte deaktiviert,
# es wird auf Google Maps verlinkt.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=""

# --- Cloudflare Turnstile (Spam-Schutz, optional) --------------------
# Solange leer, wird das Formular ohne Turnstile-Prüfung gesendet.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- E-Mail-Versand (Resend) -----------------------------------------
# API-Key von https://resend.com  – nur server-seitig, nie NEXT_PUBLIC!
RESEND_API_KEY=""
# Empfänger der Verkaufsanfragen:
CONTACT_EMAIL="wegnerautohaus@gmail.com"
# Absender-Adresse. Muss eine in Resend verifizierte Domain sein.
# Bis zur eigenen Domain kann "onboarding@resend.dev" zum Testen dienen.
MAIL_FROM="Wegner Automobile <onboarding@resend.dev>"
